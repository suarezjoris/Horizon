{
  "productName": "Horizon",
  "version": "0.1.0",
  "identifier": "com.horizon.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Horizon",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; connect-src 'self' http://localhost:11434 http://127.0.0.1:8188",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Documents/Claude RAG/images/**", "$HOME/Documents/Claude RAG/characters/**"]
      }
    }
  }
}
